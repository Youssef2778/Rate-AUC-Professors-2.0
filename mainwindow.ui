         <string notr="true">/* The background of the whole page */
QTableWidget {
    background-color: #0b2239; /* Darker blue to match your theme */
    border: none;
    gridline-color: transparent;
    outline: 0;
}

/* The Professor &quot;Cards&quot; */
QTableWidget::item {
    background-color: #1d8e9e; 
    border-radius: 15px; /* Softer rounded corners */
    margin: 4px;
    color: white;
    padding: 10px;
}

/* The Header Bar */
QHeaderView::section {
    background-color: #0b2239;
    color: #3decfc;
    border: none;
    font-weight: bold;
    font-size: 14px;
}</string>
